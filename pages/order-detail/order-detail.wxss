.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
}

.info-card {
  background: var(--surface);
  margin: 18rpx 32rpx 0;
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.info-name {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--text);
}

.info-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.info-status.pending {
  background: var(--gold-light);
  color: #8a703a;
}

.info-status.completed {
  background: var(--green-light);
  color: var(--green);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.info-val {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.info-val.link {
  color: var(--primary);
}

.info-val.fee {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
}

.section-card {
  background: var(--surface);
  margin: 18rpx 32rpx 0;
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-action {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 6rpx 18rpx;
  border: 1.5rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.section-action:active {
  background: var(--primary-light);
}

.product-row {
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.product-row:last-child {
  border-bottom: none;
}

.product-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.product-name {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 500;
  flex: 1;
}

.product-tags {
  display: flex;
  gap: 6rpx;
  margin-top: 6rpx;
}

.product-tag {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg);
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.product-formula {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.product-formula.old {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.product-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
  white-space: nowrap;
  margin-left: 16rpx;
}

.record-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.record-item:last-child {
  border-bottom: none;
}

.record-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.record-worker {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.record-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.record-detail {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.empty-tip {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.bottom-spacer {
  height: 160rpx;
}

.profit-card {
  background: var(--surface);
  margin: 18rpx 32rpx 0;
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  border-left: 4rpx solid var(--primary);
}

.profit-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 16rpx;
}

.profit-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.profit-row:last-child {
  border-bottom: none;
}

.profit-total {
  padding-top: 12rpx;
  margin-top: 4rpx;
  border-top: 2rpx solid var(--border);
}

.profit-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.profit-val {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.profit-val.income {
  color: var(--green);
}

.profit-val.cost {
  color: var(--red);
}

.profit-val.profit {
  color: var(--green);
  font-size: 34rpx;
}

.profit-val.loss {
  color: var(--red);
  font-size: 34rpx;
}

.profit-note {
  display: block;
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-top: 10rpx;
  line-height: 1.4;
}

.form-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.form-overlay.show {
  background: rgba(31,26,22,0.40);
  opacity: 1;
  pointer-events: auto;
}

.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.form-sheet.show {
  transform: translateY(0);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.form-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}

.form-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.form-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 40rpx;
}

.field-row {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
  background: var(--surface);
}

.picker-display {
  height: 80rpx;
  line-height: 80rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  letter-spacing: 0.04em;
  margin-top: 8rpx;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.overlay.show {
  background: rgba(31,26,22,0.40);
  opacity: 1;
  pointer-events: auto;
}

.link-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.link-sheet.show {
  transform: translateY(0);
}

.link-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.link-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.link-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.link-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 12rpx;
}

.link-hint {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 14rpx;
}

.link-item {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.link-item:active {
  background: var(--bg);
}

.link-check {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--text-muted);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.link-check.checked {
  background: var(--primary);
  border-color: var(--primary);
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.link-content {
  flex: 1;
}

.link-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 4rpx;
}

.link-worker {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.link-date {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.link-detail {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.link-bottom {
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
}

.link-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
}

.link-btn:active {
  opacity: 0.85;
}

.confirm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.confirm-dialog {
  width: 560rpx;
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx 32rpx;
  box-shadow: var(--shadow-lg);
}

.confirm-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  text-align: center;
}

.confirm-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 32rpx;
}

.confirm-actions {
  display: flex;
  gap: 14rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  font-weight: 600;
}

.confirm-btn.cancel {
  background: var(--primary-light);
  color: var(--text);
}

.confirm-btn.danger {
  background: var(--red);
  color: #fff;
}

.confirm-btn:active {
  opacity: 0.85;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255,252,247,0.92);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--border-light);
  display: flex;
  gap: 14rpx;
  z-index: 100;
}

.bottom-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-md);
  font-size: 30rpx;
  font-weight: 600;
}

.bottom-btn.primary {
  background: var(--primary);
  color: #fff;
}

.bottom-btn.danger {
  background: var(--red);
  color: #fff;
}

.bottom-btn:active {
  opacity: 0.85;
}
