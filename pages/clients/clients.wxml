<view class="page-wrap">
  <view class="list-wrap" wx:if="{{clients.length > 0}}">
    <view class="client-card" wx:for="{{clients}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}" bindlongpress="confirmDelete" data-id="{{item._id}}" data-name="{{item.name}}">
      <view class="card-top">
        <text class="client-name">{{item.name}}</text>
        <text class="client-status {{item.active ? 'active' : 'inactive'}}">{{item.active ? '在合作' : '已停止'}}</text>
      </view>
      <text class="client-phone">{{item.phone || '未填写手机号'}}</text>
    </view>
  </view>

  <view class="empty-tip" wx:if="{{clients.length === 0}}">
    <text>暂无拿货商\n请点击下方「添加客户」</text>
  </view>

  <view class="bottom-bar">
    <view class="add-btn" bindtap="openAddForm">+ 添加客户</view>
  </view>

  <view class="form-overlay {{showForm ? 'show' : ''}}" bindtap="closeForm">
    <view class="form-sheet {{showForm ? 'show' : ''}}" catchtap="stopPropagation">
      <view class="form-header">
        <text class="form-title">{{editingId ? '编辑客户' : '添加客户'}}</text>
        <text class="form-close" bindtap="closeForm">取消</text>
      </view>
      <view class="form-body">
        <view class="field-row">
          <text class="field-label">客户名称 *</text>
          <input class="field-input" placeholder="填写客户名称" value="{{formName}}" bindinput="onNameInput" />
        </view>
        <view class="field-row">
          <text class="field-label">手机号</text>
          <input class="field-input" placeholder="选填" value="{{formPhone}}" bindinput="onPhoneInput" />
        </view>
        <view class="field-row">
          <text class="field-label">地址</text>
          <input class="field-input" placeholder="选填" value="{{formAddress}}" bindinput="onAddressInput" />
        </view>
        <view class="field-row">
          <text class="field-label">备注</text>
          <input class="field-input" placeholder="选填" value="{{formNote}}" bindinput="onNoteInput" />
        </view>
        <view class="submit-btn" bindtap="saveClient">{{editingId ? '保存修改' : '确认添加'}}</view>
      </view>
    </view>
  </view>

  <view class="confirm-overlay {{showDeleteConfirm ? 'show' : ''}}" bindtap="cancelDelete">
    <view class="confirm-dialog" catchtap="stopPropagation">
      <text class="confirm-title">删除客户</text>
      <text class="confirm-desc">确定删除「{{deleteTargetName}}」？该操作不可撤销。</text>
      <view class="confirm-actions">
        <view class="confirm-btn cancel" bindtap="cancelDelete">取消</view>
        <view class="confirm-btn danger" bindtap="doDelete">确认删除</view>
      </view>
    </view>
  </view>
</view>
