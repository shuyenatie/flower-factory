.page-wrap {
  min-height: 100vh;
  background: var(--bg);
  display: flex;
  flex-direction: column;
}

.list-wrap {
  flex: 1;
  padding: 24rpx 32rpx 180rpx;
}

.client-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-md);
}

.client-card:active {
  transform: scale(0.98);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.client-name {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}

.client-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.client-status.active {
  background: var(--green-light);
  color: var(--green);
}

.client-status.inactive {
  background: var(--red-light);
  color: var(--red);
}

.client-phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.card-actions {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
  gap: 12rpx;
}

.action-btn {
  font-size: 26rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--bg);
  color: var(--text-secondary);
}

.action-btn.danger {
  background: var(--red-light);
  color: var(--red);
}

.action-btn.danger:active {
  background: #f0d5d0;
}

.empty-tip {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
  text-align: center;
  padding: 120rpx 32rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255,252,247,0.92);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--border-light);
  z-index: 100;
}

.add-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  letter-spacing: 0.04em;
}

.add-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.form-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.form-overlay.show {
  background: rgba(31,26,22,0.40);
  opacity: 1;
  pointer-events: auto;
}

.form-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.form-sheet.show {
  transform: translateY(0);
}

.form-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.form-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}

.form-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.form-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 40rpx;
}

.field-row {
  margin-bottom: 24rpx;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

.field-input {
  width: 100%;
  height: 80rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
  background: var(--surface);
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  letter-spacing: 0.04em;
  margin-top: 8rpx;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.confirm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.confirm-dialog {
  width: 560rpx;
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx 32rpx;
  box-shadow: var(--shadow-lg);
}

.confirm-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  text-align: center;
}

.confirm-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 32rpx;
}

.confirm-actions {
  display: flex;
  gap: 14rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  font-weight: 600;
}

.confirm-btn.cancel {
  background: var(--primary-light);
  color: var(--text);
}

.confirm-btn.danger {
  background: var(--red);
  color: #fff;
}

.confirm-btn:active {
  opacity: 0.85;
}
