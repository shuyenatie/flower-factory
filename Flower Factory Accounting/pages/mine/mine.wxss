.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.month-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 24rpx 32rpx 18rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border-light);
}

.month-pickers {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.month-nav-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.month-nav {
  font-size: 28rpx;
  color: var(--primary);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
  background: var(--primary-light);
}

.month-nav:active {
  background: #d5dce5;
}

.month-nav {
  font-size: 34rpx;
  color: var(--primary);
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.month-nav:active {
  background: var(--primary-light);
}

.picker-group {
  display: flex;
  align-items: center;
}

.month-year {
  font-size: 46rpx;
  font-weight: bold;
  color: var(--primary);
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 12rpx;
  min-width: 130rpx;
  text-align: center;
}

.month-text {
  font-size: 52rpx;
  font-weight: bold;
  color: var(--text);
  padding: 8rpx 20rpx;
  min-width: 100rpx;
  text-align: center;
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--surface);
  margin-bottom: 4rpx;
}

.summary-label {
  font-size: 32rpx;
  color: var(--text-secondary);
}

.summary-amount {
  font-size: 42rpx;
  font-weight: bold;
  color: var(--primary);
}

.summary-list {
  flex: 1;
  overflow-y: scroll;
}

.list-inner {
  padding: 16rpx 32rpx;
}

.search-bar {
  padding: 0 0 16rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: var(--primary-light);
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.worker-card {
  background: var(--surface);
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.worker-card:active {
  background: var(--bg);
}

.worker-summary {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx;
}

.worker-summary:active {
  background: var(--bg);
}

.worker-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.worker-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--text);
}

.worker-qty {
  font-size: 30rpx;
  color: var(--text-tertiary);
}

.worker-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.worker-amount {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary);
}

.expand-icon {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-list {
  border-top: 1rpx solid var(--border-light);
  background: var(--bg);
  padding: 4rpx 28rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-light);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-date {
  color: var(--text-tertiary);
  min-width: 90rpx;
}

.detail-product {
  flex: 1;
  color: var(--text);
  font-weight: 500;
}

.detail-qty {
  color: var(--text-tertiary);
  text-align: right;
  min-width: 140rpx;
}

.detail-amount {
  font-weight: bold;
  color: var(--text);
  text-align: right;
  min-width: 100rpx;
}

.empty-tip {
  text-align: center;
  padding: 120rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.bottom-bar {
  padding: 12rpx 24rpx 6rpx;
  background: var(--bg);
  display: flex;
  gap: 16rpx;
}

.bottom-btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  background: var(--primary);
  border-radius: 16rpx;
  text-align: center;
}

.bottom-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.bottom-btn[disabled] {
  background: var(--border);
  color: var(--text-tertiary);
}

.export-btn {
  background: var(--green);
}

.export-btn[disabled] {
  background: var(--border);
  color: var(--text-tertiary);
}

.manage-bar {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 8rpx 24rpx 20rpx;
  background: var(--bg);
}

.manage-link {
  font-size: 29rpx;
  color: var(--text-secondary);
  padding: 12rpx 24rpx;
  background: var(--surface);
  border-radius: 28rpx;
  box-shadow: var(--shadow-sm);
  font-weight: 500;
  white-space: nowrap;
}

.top-links {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 32rpx 8rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border-light);
}

.top-link {
  font-size: 28rpx;
  color: var(--primary);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.top-link:active {
  background: var(--primary-light);
}

.link-divider {
  font-size: 24rpx;
  color: var(--text-muted);
}

.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.35);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.25s;
}

.edit-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.edit-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: 24rpx 24rpx 0 0;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
}

.edit-sheet.show {
  transform: translateY(0);
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.edit-title {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text);
}

.edit-close {
  font-size: 30rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.edit-close:active {
  background: var(--border-light);
  border-radius: 8rpx;
}

.edit-body {
  flex: 1;
  overflow-y: scroll;
  padding: 8rpx 32rpx 12rpx;
  -webkit-overflow-scrolling: touch;
}

.edit-worker-row {
  margin-bottom: 18rpx;
}

.edit-worker-name {
  font-size: 46rpx;
  font-weight: bold;
  color: var(--primary);
}

.sheet-tip {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin-bottom: 18rpx;
  padding-left: 4rpx;
  font-weight: 500;
}

.grid-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  width: 100%;
  box-sizing: border-box;
}

.product-card {
  padding: 24rpx 16rpx;
  background: var(--surface);
  border-radius: 16rpx;
  border: 1rpx solid var(--border);
  box-sizing: border-box;
  text-align: center;
  transition: all 0.15s;
}

.product-card:active {
  transform: scale(0.96);
}

.product-card.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.product-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: var(--text);
}

.product-price {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
}

.edit-qty {
  padding: 24rpx 32rpx 40rpx;
  border-top: 1rpx solid var(--border-light);
  background: var(--bg);
}

.qty-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 18rpx;
  display: block;
}

.qty-quick {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.qty-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: var(--surface);
  border: 1rpx solid var(--border);
  border-radius: 14rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--primary);
}

.qty-btn:active {
  background: var(--primary);
  color: var(--surface);
  border-color: var(--primary);
}

.qty-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.qty-label {
  font-size: 30rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-input {
  flex: 1;
  height: 84rpx;
  border: 1rpx solid var(--border);
  border-radius: 14rpx;
  padding: 0 24rpx;
  font-size: 42rpx;
  text-align: center;
  background: var(--surface);
}

.qty-unit {
  font-size: 30rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-preview {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary);
  text-align: center;
  padding: 14rpx 0 18rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  background: var(--primary);
  border-radius: 16rpx;
  text-align: center;
}

.submit-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}
