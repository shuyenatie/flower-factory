.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.tab-bar {
  display: flex;
  margin: 18rpx 32rpx 0;
  background: var(--surface);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.tab-item {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-tertiary);
  font-weight: 500;
  position: relative;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 3rpx;
  background: var(--primary);
  border-radius: 2rpx;
}

.order-scroll {
  flex: 1;
  overflow-y: auto;
}

.list-wrap {
  padding: 18rpx 32rpx 180rpx;
}

.order-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-md);
}

.order-card:active {
  transform: scale(0.98);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.card-client {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
}

.card-order-no {
  font-size: 26rpx;
  color: var(--primary);
  background: var(--primary-light);
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.card-status {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.card-status.pending {
  background: var(--gold-light);
  color: #8a703a;
}

.card-status.completed {
  background: var(--green-light);
  color: var(--green);
}

.card-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6rpx;
}

.card-label {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.card-val {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.card-val.fee {
  color: var(--primary);
  font-weight: 700;
  font-size: 32rpx;
}

.card-products {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border-light);
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.card-product {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.card-actions {
  margin-top: 14rpx;
  display: flex;
  justify-content: flex-end;
}

.action-del {
  font-size: 24rpx;
  color: var(--red);
  padding: 8rpx 20rpx;
  background: var(--red-light);
  border-radius: var(--radius-sm);
}

.action-del:active {
  background: #f0d5d0;
}

.load-more {
  text-align: center;
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.empty-tip {
  text-align: center;
  padding: 120rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
}

.confirm-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.confirm-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.confirm-dialog {
  width: 560rpx;
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 40rpx 36rpx 32rpx;
  box-shadow: var(--shadow-lg);
}

.confirm-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 16rpx;
  text-align: center;
}

.confirm-desc {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
  text-align: center;
  margin-bottom: 32rpx;
}

.confirm-actions {
  display: flex;
  gap: 16rpx;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: var(--radius-sm);
  font-size: 30rpx;
  font-weight: 600;
}

.confirm-btn.cancel {
  background: var(--primary-light);
  color: var(--text);
}

.confirm-btn.danger {
  background: var(--red);
  color: #fff;
}

.confirm-btn:active {
  opacity: 0.85;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255,252,247,0.92);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--border-light);
  z-index: 100;
}

.add-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  letter-spacing: 0.04em;
}

.add-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}
