.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.date-header {
  background: var(--surface);
  padding: 28rpx 32rpx 20rpx;
  position: relative;
}

.date-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1rpx;
  background: var(--border-light);
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-text {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
}

.date-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
  padding: 4rpx 8rpx;
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: var(--surface);
  margin-bottom: 4rpx;
}

.summary-count {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.summary-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
}

.record-list {
  flex: 1;
  overflow-y: auto;
}

.list-inner {
  padding: 16rpx 32rpx;
}

.search-bar {
  padding: 0 0 16rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: var(--primary-light);
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.worker-group {
  background: var(--surface);
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

.worker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
}

.worker-row:active {
  background: var(--bg);
}

.worker-row-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.worker-row-name {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text);
}

.worker-row-qty {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.worker-row-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.worker-row-amount {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--accent);
}

.expand-icon {
  font-size: 24rpx;
  color: var(--text-muted);
}

.detail-list {
  border-top: 1rpx solid var(--border-light);
  background: var(--bg);
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border-light);
}

.detail-item:last-child {
  border-bottom: none;
}

.detail-item:active {
  background: var(--border-light);
}

.detail-product {
  flex: 1;
  color: var(--text);
  font-weight: 500;
}

.detail-qty {
  color: var(--text-tertiary);
  text-align: right;
  min-width: 140rpx;
}

.detail-amount {
  font-weight: 600;
  color: var(--text);
  text-align: right;
  min-width: 100rpx;
}

.edit-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.edit-overlay.show {
  background: rgba(31,26,22,0.40);
  opacity: 1;
  pointer-events: auto;
}

.edit-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.edit-sheet.show {
  transform: translateY(0);
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.edit-title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
}

.edit-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.edit-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 12rpx;
}

.edit-worker-row {
  margin-bottom: 18rpx;
}

.edit-worker-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.sheet-tip {
  font-size: 30rpx;
  color: var(--text-tertiary);
  margin-bottom: 18rpx;
  padding-left: 4rpx;
  font-weight: 500;
}

.grid-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  width: 100%;
  box-sizing: border-box;
}

.product-card {
  padding: 28rpx 16rpx;
  background: var(--surface);
  border-radius: var(--radius-md);
  border: 1.5rpx solid var(--border-light);
  box-sizing: border-box;
  text-align: center;
  transition: all 0.15s;
}

.product-card:active {
  transform: scale(0.96);
}

.product-card.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.product-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.product-price {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.edit-qty {
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  border-top: 1rpx solid var(--border-light);
  background: var(--bg);
}

.qty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 18rpx;
  display: block;
}

.qty-quick {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.qty-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.qty-btn:active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.qty-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.qty-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-input {
  flex: 1;
  height: 84rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 40rpx;
  text-align: center;
  background: var(--surface);
  color: var(--text);
}

.qty-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-preview {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
  text-align: center;
  padding: 14rpx 0 18rpx;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.empty-tip {
  text-align: center;
  padding: 120rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
}
