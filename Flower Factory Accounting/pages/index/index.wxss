.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.date-header {
  background: var(--surface);
  padding: 28rpx 32rpx 20rpx;
  position: relative;
}

.date-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 32rpx;
  right: 32rpx;
  height: 1rpx;
  background: var(--border-light);
}

.date-picker {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.date-text {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--text);
  letter-spacing: -0.02em;
}

.date-arrow {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 6rpx;
  padding: 4rpx 8rpx;
}

.worker-grid {
  flex: 1;
  overflow-y: auto;
}

.grid-inner {
  padding: 28rpx 32rpx 8rpx;
}

.section-header {
  margin-bottom: 20rpx;
  padding: 0 4rpx;
}

.section-header text {
  font-size: 30rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.search-bar {
  padding: 4rpx 0 18rpx;
}

.search-input {
  width: 100%;
  height: 66rpx;
  background: var(--primary-light);
  border-radius: 33rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.grid-2col {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
  width: 100%;
  box-sizing: border-box;
}

.worker-btn {
  padding: 42rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  box-sizing: border-box;
  transition: transform 0.15s;
  position: relative;
  overflow: hidden;
}

.worker-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  opacity: 0.5;
}

.worker-btn:active {
  transform: scale(0.96);
}

.worker-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  letter-spacing: 0.02em;
}

.empty-tip {
  text-align: center;
  padding: 100rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
}

.manage-bar {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 12rpx 24rpx 20rpx;
}

.manage-link {
  font-size: 29rpx;
  color: var(--text-secondary);
  padding: 12rpx 24rpx;
  background: var(--surface);
  border-radius: 28rpx;
  box-shadow: var(--shadow-sm);
  font-weight: 500;
  white-space: nowrap;
}

.manage-link:active {
  background: var(--border-light);
}

.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.sheet-overlay.show {
  background: rgba(31,26,22,0.40);
  opacity: 1;
  pointer-events: auto;
}

.sheet-container {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 88vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.sheet-container.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 44rpx;
  height: 6rpx;
  background: var(--border);
  border-radius: 3rpx;
  margin: 14rpx auto 0;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx 14rpx;
}

.sheet-worker-name {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--primary);
}

.sheet-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.sheet-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 12rpx;
}

.sheet-tip {
  font-size: 30rpx;
  color: var(--text-tertiary);
  margin-bottom: 18rpx;
  padding-left: 4rpx;
  font-weight: 500;
}

.product-search {
  padding: 0 0 14rpx;
}

.product-search-input {
  width: 100%;
  height: 62rpx;
  background: var(--primary-light);
  border-radius: 31rpx;
  padding: 0 28rpx;
  font-size: 26rpx;
  color: var(--text);
  box-sizing: border-box;
}

.product-card {
  padding: 28rpx 16rpx;
  background: var(--surface);
  border-radius: var(--radius-md);
  border: 1.5rpx solid var(--border-light);
  box-sizing: border-box;
  text-align: center;
  transition: all 0.15s;
}

.product-card:active {
  transform: scale(0.96);
}

.product-card.active {
  border-color: var(--primary);
  background: var(--primary-light);
}

.product-name {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.product-price {
  display: block;
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-top: 6rpx;
}

.sheet-qty {
  padding: 24rpx 32rpx calc(env(safe-area-inset-bottom) + 20rpx);
  border-top: 1rpx solid var(--border-light);
  background: var(--bg);
}

.qty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 18rpx;
  display: block;
}

.qty-quick {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.qty-btn {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 32rpx;
  font-weight: 600;
  color: var(--primary);
}

.qty-btn:active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.qty-input-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.qty-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-input {
  flex: 1;
  height: 84rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 40rpx;
  text-align: center;
  background: var(--surface);
  color: var(--text);
}

.qty-unit {
  font-size: 28rpx;
  color: var(--text-secondary);
  white-space: nowrap;
}

.qty-preview {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
  text-align: center;
  padding: 14rpx 0 18rpx;
}

.dashboard-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: var(--shadow-md);
}

.dashboard-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.dashboard-month {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text);
}

.dashboard-link {
  font-size: 26rpx;
  color: var(--text-tertiary);
  padding: 6rpx 12rpx;
}

.month-workers {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.month-worker-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.month-worker-row:last-child {
  border-bottom: none;
}

.mw-name {
  font-size: 30rpx;
  color: var(--text);
  font-weight: 500;
}

.mw-amount {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
}

/* Dashboard Stats */
.dashboard-stats {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.stat-item {
  flex: 1;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  padding: 16rpx 12rpx;
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.dashboard-amount {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 14rpx;
  border-top: 1rpx solid var(--border-light);
}

.amount-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.amount-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--accent);
}

/* Submit button in sheet */
.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.submit-btn[disabled] {
  opacity: 0.4;
  transform: none;
}
