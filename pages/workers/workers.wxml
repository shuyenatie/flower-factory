<view class="page-wrap">
  <view class="header-bar">
    <text class="header-title">工人管理</text>
    <view class="header-actions">
      <view class="header-icon-btn primary" bindtap="showAddPopup" hover-class="icon-btn-hover">
        <text class="icon-btn-icon">+</text>
        <text class="icon-btn-text">工人</text>
      </view>
      <view class="header-edit-btn {{isEditMode ? 'active' : ''}}" bindtap="toggleEditMode">
        <text wx:if="{{!isEditMode}}">编辑</text>
        <text wx:else>取消</text>
      </view>
    </view>
  </view>

  <scroll-view class="list-scroll" scroll-y>
    <view class="list-inner">
      <view class="search-bar">
        <input class="search-input" placeholder="搜索工人姓名" value="{{searchText}}" bindinput="onSearchInput" />
      </view>
      <view class="worker-item" wx:for="{{filteredWorkers}}" wx:key="_id">
        <view class="worker-info" bindtap="{{isEditMode ? '' : 'showEdit'}}" data-item="{{item}}">
          <view class="worker-row">
            <text class="worker-name">{{item.name}}</text>
          </view>
          <text class="worker-detail" wx:if="{{item.phone || item.idNumber}}">{{item.phone || ''}}  {{item.idNumber || ''}}</text>
        </view>
        <view class="product-actions" wx:if="{{!isEditMode}}">
          <view class="edit-btn" bindtap="showEdit" data-item="{{item}}">编辑</view>
        </view>
        <view class="checkbox-area" wx:if="{{isEditMode}}">
          <view class="checkbox {{checkedMap[item._id] ? 'checked' : ''}}"
                bindtap="toggleCheck" data-id="{{item._id}}"></view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{workers.length == 0}}">
        <text>暂无工人</text>
      </view>
    </view>
  </scroll-view>

  <view class="delete-bar" wx:if="{{isEditMode}}">
    <button class="delete-btn" bindtap="deleteSelected" disabled="{{!hasChecked}}">
      删除选中（{{checkedIds.length}}）
    </button>
  </view>

  <view class="popup-overlay" wx:if="{{showAddPopup}}" bindtap="hideAddPopup">
    <view class="popup-box" catchtap="stopPropagation">
      <text class="popup-title">添加工人</text>
      <input class="popup-input" placeholder="输入工人姓名"
             value="{{newName}}" bindinput="onNameInput" />
      <input class="popup-input" placeholder="手机号（选填）"
             value="{{newPhone}}" bindinput="onPhoneInput" />
      <input class="popup-input" placeholder="身份证号（选填）"
             value="{{newIdNumber}}" bindinput="onIdNumberInput" />
      <view class="popup-btns">
        <button class="popup-btn cancel" bindtap="hideAddPopup">取消</button>
        <button class="popup-btn confirm" bindtap="addWorker">确认</button>
      </view>
    </view>
  </view>

  <view class="popup-overlay" wx:if="{{showEditPopup}}" bindtap="hideEditPopup">
    <view class="popup-box" catchtap="stopPropagation">
      <text class="popup-title">编辑工人</text>
      <input class="popup-input" placeholder="输入工人姓名"
             value="{{editName}}" bindinput="onEditNameInput" />
      <input class="popup-input" placeholder="手机号（选填）"
             value="{{editPhone}}" bindinput="onEditPhoneInput" />
      <input class="popup-input" placeholder="身份证号（选填）"
             value="{{editIdNumber}}" bindinput="onEditIdNumberInput" />
      <view class="popup-btns">
        <button class="popup-btn cancel" bindtap="hideEditPopup">取消</button>
        <button class="popup-btn confirm" bindtap="saveWorker">保存</button>
      </view>
    </view>
  </view>
</view>
