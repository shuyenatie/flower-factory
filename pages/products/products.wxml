<view class="page-wrap">
  <view class="header-bar">
    <text class="header-title">花型管理</text>
    <view class="header-actions">
      <view class="header-icon-btn" bindtap="showOrderPopup" hover-class="icon-btn-hover">
        <text class="icon-btn-icon">+</text>
        <text class="icon-btn-text">单号</text>
      </view>
      <view class="header-icon-btn primary" bindtap="showAddPopup" hover-class="icon-btn-hover">
        <text class="icon-btn-icon">+</text>
        <text class="icon-btn-text">花型</text>
      </view>
      <view class="header-edit-btn {{isEditMode ? 'active' : ''}}" bindtap="toggleEditMode">
        <text wx:if="{{!isEditMode}}">编辑</text>
        <text wx:else>取消</text>
      </view>
    </view>
  </view>

  <scroll-view class="tag-scroll" scroll-x wx:if="{{allOrderNos.length > 0}}">
    <view class="tag-list">
      <view class="tag-item {{currentOrderNo == '' ? 'active' : ''}}" bindtap="selectOrderNo" data-no="">
        <text class="tag-name">全部</text>
        <text class="tag-count">{{products.length}}</text>
      </view>
      <view class="tag-item {{currentOrderNo == no ? 'active' : ''}}" wx:for="{{allOrderNos}}" wx:key="*this" bindtap="selectOrderNo" data-no="{{item}}">
        <text class="tag-name">#{{item}}</text>
        <text class="tag-count">{{orderNoCounts[item] || 0}}</text>
      </view>
    </view>
  </scroll-view>

  <scroll-view class="list-scroll" scroll-y>
    <view class="list-inner">
      <view class="search-bar">
        <input class="search-input" placeholder="搜索型号或花型名称" value="{{searchText}}" bindinput="onSearchInput" />
      </view>

      <view class="order-label" wx:if="{{currentOrderNo}}">
        <text class="order-label-text">#{{currentOrderNo}} 下的花型（{{filteredProducts.length}}个）</text>
        <text class="order-label-del" bindtap="deleteOrderGroup" data-no="{{currentOrderNo}}">删除单号</text>
      </view>

      <view class="product-item" wx:for="{{filteredProducts}}" wx:key="_id" data-item="{{item}}">
        <view class="product-info">
          <text class="product-name">{{item.modelNo}}-{{item.name}}</text>
          <view class="product-meta">
            <text class="meta-item" wx:if="{{item.modelNo}}">型号 {{item.modelNo}}</text>
            <text class="meta-item" wx:if="{{item.defaultHandsPerPiece}}">{{item.defaultHandsPerPiece}}手/枝</text>
            <text class="meta-item order-no" wx:for="{{item.orderNos || []}}" wx:key="*this">{{item}}</text>
          </view>
          <view class="product-prices">
            <text class="price-item">加工 {{item.price}}元</text>
            <text class="price-item supply" wx:if="{{item.supplyPrice}}">拿货 {{item.supplyPrice}}元</text>
          </view>
        </view>
        <view class="product-actions" wx:if="{{!isEditMode}}">
          <view class="edit-btn" bindtap="showEdit" data-item="{{item}}">编辑</view>
        </view>
        <view class="checkbox-area" wx:if="{{isEditMode}}">
          <view class="checkbox {{checkedMap[item._id] ? 'checked' : ''}}"
                bindtap="toggleCheck" data-id="{{item._id}}"></view>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{filteredProducts.length == 0}}">
        <text>暂无花型\n点击上方「+ 添加花型」创建</text>
      </view>
    </view>
  </scroll-view>

  <view class="delete-bar" wx:if="{{isEditMode}}">
    <button class="delete-btn" bindtap="deleteSelected" disabled="{{!hasChecked}}">
      删除选中（{{checkedIds.length}}）
    </button>
    <view class="clear-btn" bindtap="clearAllData">清空所有数据</view>
  </view>

  <view class="popup-overlay" wx:if="{{showAddPopup}}" bindtap="hideAddPopup">
    <view class="popup-box" catchtap="stopPropagation">
      <text class="popup-title">添加花型</text>
      <text class="popup-label" wx:if="{{currentOrderNo}}">当前单号：#{{currentOrderNo}}</text>
      <input class="popup-input" placeholder="花型名称（如 九头大丽花）"
             value="{{newName}}" bindinput="onNameInput" />
      <input class="popup-input" placeholder="型号（如 144422）"
             value="{{newModelNo}}" bindinput="onModelNoInput" />
      <input class="popup-input" placeholder="每枝手数（如 76）" type="number"
             value="{{newHandsPerPiece}}" bindinput="onHandsPerPieceInput" />
      <input class="popup-input" placeholder="加工价（元）" type="digit"
             value="{{newPrice}}" bindinput="onPriceInput" />
      <input class="popup-input" placeholder="拿货价（元，选填）" type="digit"
             value="{{newSupplyPrice}}" bindinput="onSupplyPriceInput" />
      <view class="popup-btns">
        <button class="popup-btn cancel" bindtap="hideAddPopup">取消</button>
        <button class="popup-btn confirm" bindtap="addProduct">确认</button>
      </view>
    </view>
  </view>

  <view class="popup-overlay" wx:if="{{showOrderPopup}}" bindtap="hideOrderPopup">
    <view class="popup-box" catchtap="stopPropagation">
      <text class="popup-title">新建单号</text>
      <input class="popup-input" placeholder="输入单号，如 188d-2"
             value="{{newOrderInput}}" bindinput="onNewOrderInput" />
      <view class="popup-btns">
        <button class="popup-btn cancel" bindtap="hideOrderPopup">取消</button>
        <button class="popup-btn confirm" bindtap="addOrderGroup">创建</button>
      </view>
    </view>
  </view>

  <view class="popup-overlay" wx:if="{{showEditPopup}}" bindtap="hideEditPopup">
    <view class="popup-box" catchtap="stopPropagation">
      <text class="popup-title">编辑花型</text>
      <input class="popup-input" placeholder="花型名称"
             value="{{editName}}" bindinput="onEditNameInput" />
      <input class="popup-input" placeholder="型号"
             value="{{editModelNo}}" bindinput="onEditModelNoInput" />
      <input class="popup-input" placeholder="每枝手数" type="number"
             value="{{editHandsPerPiece}}" bindinput="onEditHandsPerPieceInput" />
      <input class="popup-input" placeholder="所属单号（多个用逗号隔开）"
             value="{{editOrderNos}}" bindinput="onEditOrderNosInput" />
      <input class="popup-input" placeholder="加工价（元）" type="digit"
             value="{{editPrice}}" bindinput="onEditPriceInput" />
      <input class="popup-input" placeholder="拿货价（元，选填）" type="digit"
             value="{{editSupplyPrice}}" bindinput="onEditSupplyPriceInput" />
      <view class="popup-btns">
        <button class="popup-btn cancel" bindtap="hideEditPopup">取消</button>
        <button class="popup-btn confirm" bindtap="saveProduct">保存</button>
      </view>
    </view>
  </view>
</view>
