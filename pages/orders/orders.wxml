<view class="page-wrap">
  <view class="tab-bar">
    <view class="tab-item {{tab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">进行中 ({{pendingOrders.length}})</view>
    <view class="tab-item {{tab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">已完成 ({{completedOrders.length}})</view>
  </view>

  <scroll-view class="order-scroll" scroll-y bindscrolltolower="onScrollToLower">
    <view class="list-wrap" wx:if="{{tab === 'pending'}}">
      <view class="order-card" wx:for="{{pendingOrders}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
        <view class="card-top">
          <text class="card-order-no" wx:if="{{item.orderNo}}">{{item.orderNo}}</text>
          <text class="card-client">{{item.clientName}}</text>
          <text class="card-status pending">进行中</text>
        </view>
        <view class="card-row">
          <text class="card-label">取材料</text>
          <text class="card-val">{{item.orderDate}}</text>
        </view>
        <view class="card-row" wx:if="{{item.returnDate}}">
          <text class="card-label">约定送回</text>
          <text class="card-val">{{item.returnDate}}</text>
        </view>
        <view class="card-products">
          <text class="card-product" wx:for="{{item.productList}}" wx:key="productId">
            {{item.displayName || item.productName}} × {{item.pieceCount || item.quantity}}
          </text>
        </view>
        <view class="card-actions">
          <view class="action-del" bindtap="confirmDelete" data-id="{{item._id}}" data-name="{{item.clientName}}" catchtap>删除</view>
        </view>
      </view>
      <view class="load-more" wx:if="{{pendingOrders.length > 0 && pendingMore}}">
        <text>上拉加载更多</text>
      </view>
      <view class="empty-tip" wx:if="{{pendingOrders.length === 0}}">
        <text>暂无进行中的加工单</text>
      </view>
    </view>

    <view class="list-wrap" wx:if="{{tab === 'completed'}}">
      <view class="order-card" wx:for="{{completedOrders}}" wx:key="_id">
        <view class="card-top">
          <text class="card-order-no" wx:if="{{item.orderNo}}">{{item.orderNo}}</text>
          <text class="card-client">{{item.clientName}}</text>
          <text class="card-status completed">已完成</text>
        </view>
        <view class="card-row">
          <text class="card-label">取材料</text>
          <text class="card-val">{{item.orderDate}}</text>
        </view>
        <view class="card-row" wx:if="{{item.returnDate}}">
          <text class="card-label">约定送回</text>
          <text class="card-val">{{item.returnDate}}</text>
        </view>
        <view class="card-row" wx:if="{{item.actualReturnDate}}">
          <text class="card-label">实际送回</text>
          <text class="card-val">{{item.actualReturnDate}}</text>
        </view>
        <view class="card-row" wx:if="{{item.processingFee}}">
          <text class="card-label">加工费</text>
          <text class="card-val fee">¥{{item.processingFee}}</text>
        </view>
        <view class="card-products">
          <text class="card-product" wx:for="{{item.productList}}" wx:key="productId">
            {{item.displayName || item.productName}} × {{item.pieceCount || item.quantity}}
          </text>
        </view>
      </view>
      <view class="load-more" wx:if="{{completedOrders.length > 0 && completedMore}}">
        <text>上拉加载更多</text>
      </view>
      <view class="empty-tip" wx:if="{{completedOrders.length === 0}}">
        <text>暂无已完成加工单</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="add-btn" bindtap="goCreate">+ 新建加工单</view>
  </view>

  <view class="confirm-overlay {{showDeleteConfirm ? 'show' : ''}}" bindtap="cancelDelete">
    <view class="confirm-dialog" catchtap="stopPropagation">
      <text class="confirm-title">删除加工单</text>
      <text class="confirm-desc">确定删除「{{deleteTargetName}}」的加工单？关联的计件记录仍保留，仅删除订单本身。</text>
      <view class="confirm-actions">
        <view class="confirm-btn cancel" bindtap="cancelDelete">取消</view>
        <view class="confirm-btn danger" bindtap="doDelete">确认删除</view>
      </view>
    </view>
  </view>
</view>
