.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.summary-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border-light);
}

.summary-label {
  font-size: 30rpx;
  color: var(--text-secondary);
}

.summary-amount {
  font-size: 42rpx;
  font-weight: 700;
  color: var(--green);
}

.list-scroll {
  flex: 1;
  overflow-y: auto;
}

.list-inner {
  padding: 16rpx 32rpx;
}

.income-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-md);
  position: relative;
  border-left: 4rpx solid var(--green);
}

.income-card:active {
  transform: scale(0.98);
}

.card-top-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-date {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.card-amount {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--green);
}

.card-row {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
}

.card-note-row {
  margin-top: 6rpx;
}

.card-label {
  font-size: 26rpx;
  color: var(--text-muted);
  min-width: 80rpx;
}

.card-value {
  font-size: 28rpx;
  color: var(--text);
  font-weight: 500;
}

.note-text {
  color: var(--text-secondary);
  font-weight: 400;
}

.card-value.order-no {
  color: var(--primary);
  font-weight: 600;
}

.card-del {
  position: absolute;
  right: 28rpx;
  bottom: 24rpx;
  font-size: 24rpx;
  color: var(--red);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--red);
  border-radius: var(--radius-sm);
}

.card-del:active {
  background: var(--red-light);
}

.empty-tip {
  text-align: center;
  padding: 160rpx 32rpx 80rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
}

.empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 28rpx;
  color: var(--text-muted);
}

.loading-tip {
  text-align: center;
  padding: 60rpx;
  font-size: 28rpx;
  color: var(--text-tertiary);
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 100;
}

.modal-content {
  width: 100%;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  padding: 32rpx 36rpx calc(env(safe-area-inset-bottom) + 32rpx);
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: var(--shadow-xl);
}

.modal-title {
  display: block;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  margin-top: 20rpx;
}

.form-label-opt {
  color: var(--text-tertiary);
}

.form-static {
  display: block;
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
  box-sizing: border-box;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--primary-light);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
}

.modal-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 36rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
}

.action-cancel {
  background: var(--primary-light);
  color: var(--text-secondary);
}

.action-cancel:active {
  background: var(--border);
}

.action-confirm {
  background: var(--primary);
  color: #fff;
}

.action-confirm:active {
  opacity: 0.88;
}

.bottom-bar {
  padding: 16rpx 24rpx 12rpx;
  background: var(--bg);
}

.add-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--primary);
  border-radius: var(--radius-md);
  text-align: center;
  letter-spacing: 0.04em;
}

.add-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}
