<view class="page-wrap">
  <view class="client-header" wx:if="{{client}}">
    <text class="client-big-name">{{client.name}}</text>
    <text class="client-info">📞 {{client.phone || '未填写'}}</text>
    <text class="client-info" wx:if="{{client.address}}">📍 {{client.address}}</text>
    <text class="client-info" wx:if="{{client.note}}">📝 {{client.note}}</text>
  </view>

  <view class="tab-bar">
    <view class="tab-item {{tab === 'pending' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending">
      进行中 ({{pendingOrders.length}})
    </view>
    <view class="tab-item {{tab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">
      已完成 ({{completedOrders.length}})
    </view>
  </view>

  <view class="order-list" wx:if="{{tab === 'pending'}}">
    <view class="order-card" wx:for="{{pendingOrders}}" wx:key="_id" bindtap="goOrderDetail" data-id="{{item._id}}">
      <view class="order-row">
        <text class="order-label">取材料</text>
        <text class="order-value">{{item.orderDate}}</text>
      </view>
      <view class="order-row" wx:if="{{item.returnDate}}">
        <text class="order-label">约定送回</text>
        <text class="order-value">{{item.returnDate}}</text>
      </view>
      <view class="order-products">
        <text class="order-product" wx:for="{{item.productList}}" wx:key="productId">
          {{item.productName}} × {{item.quantity}}
        </text>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{pendingOrders.length === 0}}">
      <text>暂无进行中的加工单</text>
    </view>
  </view>

  <view class="order-list" wx:if="{{tab === 'completed'}}">
    <view class="order-card" wx:for="{{completedOrders}}" wx:key="_id">
      <view class="order-row">
        <text class="order-label">取材料</text>
        <text class="order-value">{{item.orderDate}}</text>
      </view>
      <view class="order-row" wx:if="{{item.actualReturnDate}}">
        <text class="order-label">实际送回</text>
        <text class="order-value">{{item.actualReturnDate}}</text>
      </view>
      <view class="order-row" wx:if="{{item.processingFee}}">
        <text class="order-label">加工费</text>
        <text class="order-value">¥{{item.processingFee}}</text>
      </view>
      <view class="order-products">
        <text class="order-product" wx:for="{{item.productList}}" wx:key="productId">
          {{item.productName}} × {{item.quantity}}
        </text>
      </view>
    </view>
    <view class="empty-tip" wx:if="{{completedOrders.length === 0}}">
      <text>暂无已完成加工单</text>
    </view>
  </view>

  <view class="bottom-bar" wx:if="{{client}}">
    <view class="bottom-btn secondary" bindtap="openEditForm">编辑客户信息</view>
    <view class="bottom-btn primary" bindtap="goCreateOrder">+ 新建加工单</view>
  </view>

  <view class="form-overlay {{showEditForm ? 'show' : ''}}" bindtap="closeEditForm">
    <view class="form-sheet {{showEditForm ? 'show' : ''}}" catchtap="stopPropagation">
      <view class="form-header">
        <text class="form-title">编辑客户</text>
        <text class="form-close" bindtap="closeEditForm">取消</text>
      </view>
      <view class="form-body">
        <view class="field-row">
          <text class="field-label">客户名称 *</text>
          <input class="field-input" placeholder="填写客户名称" value="{{editName}}" bindinput="onEditNameInput" />
        </view>
        <view class="field-row">
          <text class="field-label">手机号</text>
          <input class="field-input" placeholder="选填" value="{{editPhone}}" bindinput="onEditPhoneInput" />
        </view>
        <view class="field-row">
          <text class="field-label">地址</text>
          <input class="field-input" placeholder="选填" value="{{editAddress}}" bindinput="onEditAddressInput" />
        </view>
        <view class="field-row">
          <text class="field-label">备注</text>
          <input class="field-input" placeholder="选填" value="{{editNote}}" bindinput="onEditNoteInput" />
        </view>
        <view class="submit-btn" bindtap="saveEdit">保存修改</view>
      </view>
    </view>
  </view>
</view>
