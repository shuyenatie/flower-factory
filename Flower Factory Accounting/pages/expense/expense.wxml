<view class="page-wrap">
  <view class="summary-bar">
    <text class="summary-label">本月支出合计</text>
    <text class="summary-amount">¥{{monthTotal}}</text>
  </view>

  <scroll-view class="list-scroll" scroll-y bindscroll="onScroll">
    <view class="list-inner">
      <view class="swipe-wrap" wx:for="{{list}}" wx:key="_id" data-id="{{item._id}}"
        bindtouchstart="touchStart" bindtouchmove="touchMove" bindtouchend="touchEnd">
        <view class="swipe-content" style="transform: translateX({{item.swipeX || 0}}px); transition: {{item._touching ? 'none' : 'transform 0.25s ease'}}">
          <view class="expense-card">
            <view class="card-top-row">
              <text class="card-date">{{item.date}}</text>
              <text class="card-amount">¥{{item.amountText}}</text>
            </view>
            <view class="card-row">
              <text class="card-label">类别</text>
              <text class="card-category">{{item.category}}</text>
            </view>
            <view class="card-row card-note-row" wx:if="{{item.note}}">
              <text class="card-label">备注</text>
              <text class="card-value note-text">{{item.note}}</text>
            </view>
          </view>
        </view>
        <view class="swipe-delete" data-id="{{item._id}}" bindtap="deleteRecord">删除</view>
      </view>

      <view class="empty-tip" wx:if="{{list.length === 0 && !loading}}">
        <text>暂无支出记录</text>
        <text class="empty-sub">点击下方按钮添加</text>
      </view>

      <view class="loading-tip" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-bar">
    <button class="add-btn" bindtap="showAddForm">+ 添 加 支 出</button>
  </view>

  <view class="modal-overlay" wx:if="{{showForm}}" bindtap="hideAddForm">
    <view class="modal-content" catchtap="noop">
      <text class="modal-title">添加支出</text>

      <text class="form-label">支出类别</text>
      <picker mode="selector" range="{{categoryRange}}" bindchange="onCategoryChange">
        <view class="form-picker">{{categoryRange[form.categoryIndex]}}</view>
      </picker>

      <text class="form-label">金额（元）</text>
      <input class="form-input" placeholder="0.00" type="digit" value="{{form.amount}}" bindinput="onFormInput" data-field="amount" />

      <text class="form-label">日期</text>
      <picker mode="date" value="{{form.date}}" bindchange="onFormDate">
        <view class="form-picker">{{form.date}}</view>
      </picker>

      <text class="form-label form-label-opt">备注（选填）</text>
      <input class="form-input" placeholder="输入备注" value="{{form.note}}" bindinput="onFormInput" data-field="note" />

      <view class="modal-actions">
        <view class="action-btn action-cancel" bindtap="hideAddForm">取消</view>
        <view class="action-btn action-confirm" bindtap="saveExpense">保存</view>
      </view>
    </view>
  </view>
</view>
