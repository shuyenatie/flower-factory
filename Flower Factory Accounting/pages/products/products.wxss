.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx;
  background: var(--surface);
  border-bottom: 1rpx solid var(--border-light);
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.header-icon-btn {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 10rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--primary-light);
  color: var(--primary);
}

.header-icon-btn.primary {
  background: var(--primary);
  color: #fff;
}

.icon-btn-icon {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.icon-btn-text {
  font-size: 26rpx;
  font-weight: 600;
}

.icon-btn-hover {
  opacity: 0.8;
}

.header-edit-btn {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 10rpx 22rpx;
  border-radius: var(--radius-sm);
  background: var(--bg);
}

.header-edit-btn.active {
  color: var(--red);
  background: var(--red-light);
}

.tag-scroll {
  white-space: nowrap;
  background: var(--surface);
  padding: 16rpx 32rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.tag-list {
  display: flex;
  gap: 12rpx;
}

.tag-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 22rpx;
  border-radius: 24rpx;
  background: var(--bg);
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.tag-item.active {
  background: var(--primary);
  color: #fff;
}

.tag-name {
  font-weight: 500;
}

.tag-count {
  font-size: 22rpx;
  opacity: 0.7;
}

.tag-item.active .tag-count {
  opacity: 0.8;
}

.list-scroll {
  flex: 1;
  overflow-y: auto;
}

.list-inner {
  padding: 16rpx 32rpx;
}

.search-bar {
  padding: 8rpx 0 16rpx;
}

.search-input {
  width: 100%;
  height: 64rpx;
  background: var(--primary-light);
  border-radius: 32rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  color: var(--text);
  box-sizing: border-box;
}

.order-label {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
  padding: 0 4rpx;
}

.order-label-text {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 500;
}

.order-label-del {
  font-size: 24rpx;
  color: var(--red);
  padding: 6rpx 14rpx;
}

.order-label-del:active {
  background: var(--red-light);
  border-radius: 8rpx;
}

.product-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: var(--surface);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin-bottom: 12rpx;
  box-shadow: var(--shadow-md);
}

.product-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  flex: 1;
}

.product-name {
  font-size: 38rpx;
  font-weight: 600;
  color: var(--text);
}

.product-meta {
  display: flex;
  gap: 10rpx;
  width: 100%;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-secondary);
  background: var(--bg);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.meta-item.order-no {
  background: var(--primary-light);
  color: var(--primary);
}

.product-prices {
  display: flex;
  gap: 10rpx;
}

.price-item {
  font-size: 26rpx;
  padding: 4rpx 14rpx;
  border-radius: var(--radius-sm);
  background: var(--primary-light);
  color: var(--primary);
  font-weight: 500;
}

.price-item.supply {
  background: var(--gold-light);
  color: #8a6e38;
}

.product-actions {
  padding: 4rpx 0 4rpx 12rpx;
}

.edit-btn {
  font-size: 26rpx;
  color: var(--primary);
  padding: 8rpx 20rpx;
  border: 1.5rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.edit-btn:active {
  background: var(--primary-light);
}

.checkbox-area {
  padding: 4rpx;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid var(--text-muted);
  border-radius: 50%;
  box-sizing: border-box;
}

.checkbox.checked {
  background: var(--red);
  border-color: var(--red);
  position: relative;
}

.checkbox.checked::after {
  content: '';
  position: absolute;
  top: 7rpx;
  left: 13rpx;
  width: 10rpx;
  height: 18rpx;
  border: solid #fff;
  border-width: 0 3rpx 3rpx 0;
  transform: rotate(45deg);
}

.empty-tip {
  text-align: center;
  padding: 80rpx 32rpx;
  font-size: 32rpx;
  color: var(--text-tertiary);
  line-height: 1.8;
}

.delete-bar {
  padding: 12rpx 24rpx 24rpx;
  background: var(--bg);
}

.delete-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  background: var(--red);
  border-radius: var(--radius-md);
  text-align: center;
}

.delete-btn:active {
  opacity: 0.88;
}

.delete-btn[disabled] {
  opacity: 0.4;
  background: var(--border);
  color: var(--text-tertiary);
}

.clear-btn {
  text-align: center;
  font-size: 26rpx;
  color: var(--red);
  padding: 16rpx 0 4rpx;
}

.clear-btn:active {
  opacity: 0.6;
}

.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.popup-box {
  width: 580rpx;
  background: var(--surface);
  border-radius: var(--radius-xl);
  padding: 48rpx 40rpx 36rpx;
  box-shadow: var(--shadow-lg);
}

.popup-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text);
  text-align: center;
  margin-bottom: 36rpx;
}

.popup-label {
  display: block;
  font-size: 28rpx;
  color: var(--primary);
  text-align: center;
  margin-bottom: 24rpx;
  font-weight: 500;
}

.popup-input {
  width: 100%;
  height: 84rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
  background: var(--bg);
  color: var(--text);
}

.popup-input:focus {
  border-color: var(--primary);
  background: var(--surface);
}

.popup-btns {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.popup-btn {
  flex: 1;
  height: 84rpx;
  line-height: 84rpx;
  font-size: 32rpx;
  border-radius: var(--radius-md);
  text-align: center;
  font-weight: 500;
}

.popup-btn.cancel {
  background: var(--primary-light);
  color: var(--text-secondary);
}

.popup-btn.confirm {
  background: var(--primary);
  color: #fff;
}
