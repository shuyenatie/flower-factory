/* ─── Design Tokens ─── */
page {
  --bg: #f1ede6;
  --surface: #fffcf7;
  --primary: #2c3a4a;
  --primary-light: #e8ecf0;
  --primary-mid: #b0bbc8;
  --accent: #c17d5a;
  --accent-light: #f5ede8;
  --green: #6b8f6b;
  --green-light: #eef5ee;
  --red: #b84a3a;
  --red-light: #f7e9e6;
  --gold: #c9a96e;
  --gold-light: #f7f0e2;
  --text: #1f1a16;
  --text-secondary: #7d736b;
  --text-tertiary: #a89f96;
  --text-muted: #c5bdb4;
  --border: #e5dfd6;
  --border-light: #f0ebe3;
  --radius-sm: 10rpx;
  --radius-md: 14rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --shadow-sm: 0 1rpx 3rpx rgba(44,36,32,0.06);
  --shadow-md: 0 2rpx 8rpx rgba(44,36,32,0.05), 0 1rpx 3rpx rgba(44,36,32,0.03);
  --shadow-lg: 0 4rpx 16rpx rgba(44,36,32,0.07);
  --shadow-xl: 0 8rpx 32rpx rgba(44,36,32,0.10);

  font-size: 28rpx;
  color: var(--text);
  background: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
  line-height: 1.5;
}

::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* ─── Shared UI Components ─── */

/* Cards */
.g-card {
  background: var(--surface);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
}

.g-card-pad {
  padding: 24rpx;
}

/* Bottom Bar */
.g-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255,252,247,0.92);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--border-light);
  z-index: 100;
}

/* Primary Button */
.g-btn-primary {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
}

.g-btn-primary:active {
  opacity: 0.88;
  transform: scale(0.98);
}

.g-btn-primary[disabled] {
  opacity: 0.4;
  transform: none;
}

/* Secondary Button */
.g-btn-secondary {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--primary-light);
  color: var(--primary);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.g-btn-secondary:active {
  opacity: 0.8;
}

/* Danger Button */
.g-btn-danger {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: var(--red);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-sm);
}

.g-btn-danger:active {
  opacity: 0.88;
}

/* Form Input */
.g-input {
  width: 100%;
  height: 80rpx;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
  transition: border-color 0.2s;
}

.g-input:focus {
  border-color: var(--primary);
}

/* Form Label */
.g-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
}

/* Static Text (for disabled form values) */
.g-static {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: var(--bg);
  border-radius: var(--radius-sm);
  padding: 0 24rpx;
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
  box-sizing: border-box;
}

/* Picker display */
.g-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

.g-picker-text {
  font-size: 32rpx;
  color: var(--text);
}

.g-picker-text.placeholder {
  color: var(--text-tertiary);
}

.g-picker-text.filled {
  color: var(--text);
}

.g-picker-arrow {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Bottom Sheet Overlay + Container */
.g-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(31,26,22,0.40);
  z-index: 999;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
}

.g-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

.g-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--surface);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  box-shadow: var(--shadow-xl);
}

.g-sheet.show {
  transform: translateY(0);
}

.g-sheet-handle {
  width: 44rpx;
  height: 6rpx;
  background: var(--border);
  border-radius: 3rpx;
  margin: 14rpx auto 0;
}

.g-sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 32rpx 12rpx;
}

.g-sheet-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text);
}

.g-sheet-close {
  font-size: 28rpx;
  color: var(--text-tertiary);
  padding: 8rpx 16rpx;
}

.g-sheet-body {
  flex: 1;
  overflow-y: auto;
  padding: 8rpx 32rpx 12rpx;
}

.g-sheet-action {
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  border-top: 1rpx solid var(--border-light);
}

/* Status Badge */
.g-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.g-badge-pending {
  background: var(--gold-light);
  color: #8a703a;
}

.g-badge-completed {
  background: var(--green-light);
  color: var(--green);
}

.g-badge-cancelled {
  background: var(--red-light);
  color: var(--red);
}

/* Empty State */
.g-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.g-empty-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: var(--border-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 20rpx;
}

.g-empty-text {
  font-size: 30rpx;
  color: var(--text-tertiary);
  text-align: center;
}

.g-empty-sub {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 8rpx;
  text-align: center;
}

/* Section title / divider */
.g-section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14rpx;
}

.g-section-sub {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 14rpx;
}

/* Tag / Chip */
.g-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg);
  border-radius: 8rpx;
}

.g-tag-primary {
  background: var(--primary-light);
  color: var(--primary);
}

/* Small pill chip */
.g-chip {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: var(--bg);
  color: var(--text-secondary);
}

.g-chip-primary {
  background: var(--primary);
  color: #fff;
}

/* Bottom spacer (to avoid bottom bar overlap) */
.g-bottom-spacer {
  height: 180rpx;
}

/* Row helpers */
.g-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.g-row-gap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
