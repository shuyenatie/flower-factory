.page-wrap {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.form-scroll {
  flex: 1;
  overflow-y: auto;
}

.form-section {
  background: var(--surface);
  margin: 18rpx 32rpx 0;
  border-radius: var(--radius-md);
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-light);
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  margin-bottom: 14rpx;
}

.section-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-header-row .section-title {
  margin-bottom: 0;
}

.add-product-btn {
  font-size: 28rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 6rpx 18rpx;
  border: 1.5rpx solid var(--primary);
  border-radius: var(--radius-sm);
}

.add-product-btn:active {
  background: var(--primary-light);
}

.picker-btn {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  box-sizing: border-box;
}

.picker-btn.disabled {
  opacity: 0.6;
  background: var(--bg);
}

.picker-text {
  font-size: 32rpx;
  color: var(--text);
}

.picker-text.placeholder {
  color: var(--text-tertiary);
}

.picker-arrow {
  font-size: 28rpx;
  color: var(--text-muted);
}

.product-card {
  background: var(--bg);
  border: 1rpx solid var(--border-light);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.product-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.product-num {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text);
}

.product-remove {
  font-size: 26rpx;
  color: var(--red);
  padding: 4rpx 12rpx;
}

.product-remove:active {
  background: var(--red-light);
  border-radius: 8rpx;
}

.product-field {
  margin-bottom: 12rpx;
  flex: 1;
}

.field-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 6rpx;
}

.field-input {
  width: 100%;
  height: 72rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
  background: var(--surface);
}

.field-hint {
  display: block;
  font-size: 22rpx;
  color: var(--primary);
  margin-top: 8rpx;
  font-weight: 500;
}

.field-input-sm {
  width: 100%;
  height: 72rpx;
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 0 20rpx;
  font-size: 32rpx;
  color: var(--text);
  box-sizing: border-box;
  background: var(--surface);
}

.row-2col {
  display: flex;
  gap: 16rpx;
}

.calc-divider {
  height: 1rpx;
  background: var(--border-light);
  margin: 4rpx 0;
}

.calc-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
  border-top: 1rpx solid var(--border-light);
  margin-top: 4rpx;
}

.calc-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.calc-val {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
}

.calc-val.amount {
  color: var(--primary);
  font-weight: 700;
}

.field-static {
  display: block;
  font-size: 32rpx;
  color: var(--primary);
  font-weight: 600;
  padding: 8rpx 0;
}

.picker-sm {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background: var(--surface);
  border: 1.5rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 32rpx;
  color: var(--text);
}

.picker-sm .placeholder {
  color: var(--text-tertiary);
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.total-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.total-val {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--primary);
}

.form-bottom {
  height: 200rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 32rpx calc(env(safe-area-inset-bottom) + 24rpx);
  background: rgba(255,252,247,0.92);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-top: 1rpx solid var(--border-light);
  z-index: 100;
}

.submit-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  background: var(--primary);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: var(--radius-md);
  letter-spacing: 0.04em;
}

.submit-btn:active {
  opacity: 0.88;
  transform: scale(0.98);
}
